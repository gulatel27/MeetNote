OPENAI_API_KEY=sk-your-openai-api-key

# OpenAI STT transcription model. whisper-1 is kept for Whisper API compatibility.
# You can also use newer transcription models such as gpt-4o-transcribe if available to your account.
OPENAI_STT_MODEL=whisper-1

# Summary/report LLM model. Change this to a model available to your account.
OPENAI_SUMMARY_MODEL=gpt-5.5

# openai or local. local currently expects a compatible local Whisper implementation to be added.
STT_PROVIDER=openai

# OpenAI audio upload limit is lower than the app upload limit, so large files are chunked before STT.
# The backend first checks FFMPEG_PATH/PATH, then falls back to the imageio-ffmpeg package.
OPENAI_STT_MAX_BYTES=25165824
STT_CHUNK_SECONDS=600
FFMPEG_PATH=ffmpeg

DATABASE_URL=sqlite:///./meeting_reports.db
UPLOAD_DIR=./uploads
REPORT_DIR=./reports
MAX_UPLOAD_BYTES=524288000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
